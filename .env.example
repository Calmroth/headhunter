# Copy to .env.local and fill in your own keys.
# These are read by Vite at build/dev time and inlined into the client bundle —
# treat them as public keys with proper referrer/HTTP-domain restrictions.

# Cesium Ion access token — get one free at https://ion.cesium.com
# Used for default Cesium services (terrain, geocoding). Optional if you only
# render Google Photorealistic 3D Tiles, but recommended.
VITE_CESIUM_ION_TOKEN=

# Google Maps Platform API key with "Map Tiles API" enabled.
# https://developers.google.com/maps/documentation/tile/3d-tiles-overview
# Restrict the key to your dev/prod HTTP referrers.
VITE_GOOGLE_3D_TILES_KEY=
